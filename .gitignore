# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Bundler
/.bundle
/vendor/bundle

# Environment & Credentials
/.env*
!.env.example
/config/master.key
/config/*.key
/config/credentials.yml.enc

# Logs & Temp Files
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Process IDs
/tmp/pids/*
!/tmp/pids/.keep

# Uploaded files & Databases
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/.keep
*.sqlite3
*.sqlite3-journal

# Assets
/public/assets
/public/packs
/public/packs-test
/app/assets/builds/*
!/app/assets/builds/.keep

# Node/Yarn
/node_modules/
/yarn-error.log
yarn-debug.log*

# IDE & Editor Files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.ruby-version.local
.ruby-gemset

# Testing & Coverage
/coverage/
*.lcov

# Kamal deployment
.kamal/
kamal-results/

# Docker Compose overrides
docker-compose.override.yml

# Ruby Version Managers
.rbenv-version
.rvmrc
